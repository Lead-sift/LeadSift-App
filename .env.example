PORT=3000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Clave "anon public" (Project Settings → API). Solo se usa en scripts de
# verificación de RLS, nunca en el backend de producción (ese usa service_role).
SUPABASE_ANON_KEY=

ANTHROPIC_API_KEY=

# Cuenta usada para ENVIAR las notificaciones de leads (no es el email de
# destino del cliente, sino el remitente del sistema). Correo alojado en
# DonDominio (administracion@leadsift.es) — usa la contraseña normal del
# buzón, y los datos SMTP que da DonDominio en "Ver datos de configuración".
EMAIL_NOTIFICACIONES_USER=
EMAIL_NOTIFICACIONES_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=

# Meta / WhatsApp Business API — App "LeadSift" en developers.facebook.com.
# En fase de pruebas se usa el número de test gratuito de Meta; el
# META_WHATSAPP_ACCESS_TOKEN de esta fase es temporal (~24h), se sustituye
# por un token permanente de System User antes de producción.
META_APP_ID=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
# Token que nosotros inventamos (cadena aleatoria) y configuramos también en
# el panel de Meta al suscribir el webhook, para el handshake de verificación.
META_WEBHOOK_VERIFY_TOKEN=
